generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  displayName   String
  profilePhoto  String?
  climbingLevel String?
  climbingType  String?
  city          String?
  state         String?
  birthday      DateTime?
  age           String?  // Add this back
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviews           Review[]
  communityPhotos   CommunityPhoto[]
  followers         Follow[] @relation("UserFollowers")
  following         Follow[] @relation("UserFollowing")
  reviewLikes       ReviewLike[]
  videos            Video[]
  videoLikes        VideoLike[]
  videoComments     VideoComment[]
  videoCommentLikes VideoCommentLike[]
  registeredGyms    Gym[]    @relation("RegisteredGyms")

  notifications        Notification[] @relation("UserNotifications")
  triggeredNotifications Notification[] @relation("ActorNotifications")

  blocks           UserBlock[] @relation("UserBlocks")
  blockedBy        UserBlock[] @relation("BlockedByUsers")
  reports          Report[]    @relation("UserReports")
  reportsAgainst   Report[]    @relation("ReportsAgainstUser")
  reviewedReports  Report[]    @relation("ReportsReviewedBy")

  savedGyms     SavedGym[]
  videoViews    VideoView[]  

  @@map("users")
}

model Review {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gymId          String
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  overallRating  Float
  setting        String   // 'creative', 'challenging', 'balanced', 'repetitive'
  difficulty     String   // 'soft', 'accurate', 'stiff'
  reviewText     String?
  photos         String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  likes          ReviewLike[]

  @@unique([userId, gymId])
  @@map("reviews")
}

model CommunityPhoto {
  id        String   @id @default(uuid())
  url       String
  gymId     String
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  caption   String?
  createdAt DateTime @default(now())

  @@map("community_photos")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model ReviewLike {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@map("review_likes")
}

model Gym {
  id                String   @id @default(uuid())
  name              String
  address           String
  city              String
  state             String
  country           String   @default("USA")
  latitude          Float
  longitude         Float
  hasRopeClimbing   Boolean  @default(false)
  hasBouldering     Boolean  @default(true)
  amenities         String[] @default([])  // Add this back
  climbingTypes     String[] @default([])  // Add this back
  officialPhotos    String[] @default([])  // Add this back
  priceRange        String?  // Add this back
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  registeredBy      String?
  registeredByUser  User?    @relation("RegisteredGyms", fields: [registeredBy], references: [id])

  reviews           Review[]
  communityPhotos   CommunityPhoto[]
  videos            Video[]

  savedGyms     SavedGym[]

  @@map("gyms")
}

model Video {
  id           String   @id @default(uuid())
  videoUrl     String
  thumbnailUrl String
  caption      String?
  gymId        String
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  views        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  likes        VideoLike[]
  comments     VideoComment[]
  videoViews   VideoView[]

  @@map("videos")
}

model VideoLike {
  id        String   @id @default(uuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([videoId, userId])
  @@map("video_likes")
}

model VideoComment {
  id        String   @id @default(uuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  parentId  String?  // For replies
  parent    VideoComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   VideoComment[] @relation("CommentReplies")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes     VideoCommentLike[]

  @@map("video_comments")
}

model VideoCommentLike {
  id        String   @id @default(uuid())
  commentId String
  comment   VideoComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@map("video_comment_likes")
}

model VideoView {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  viewedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
  @@index([userId])
  @@map("video_views")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   // Who receives the notification
  type      String   // 'follow', 'review_like', 'video_like', 'video_comment', 'comment_reply', 'new_review'
  actorId   String   // Who triggered the notification
  entityId  String?  // ID of the related entity (review, video, comment, gym)
  entityType String? // 'review', 'video', 'comment', 'gym'
  message   String   // Notification message
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor     User     @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String   // User who is blocking
  blockedId String   // User who is being blocked
  createdAt DateTime @default(now())

  blocker   User     @relation("UserBlocks", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   User     @relation("BlockedByUsers", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
  @@map("user_blocks")
}

model Report {
  id           String   @id @default(uuid())
  reporterId   String   // User who is reporting
  reportedUserId String? // User being reported (if applicable)
  contentType  String   // 'review', 'video', 'comment', 'user'
  contentId    String?  // ID of the content being reported
  reason       String   // 'spam', 'harassment', 'inappropriate', 'false_info', 'other'
  description  String?  // Optional details
  status       String   @default("pending") // 'pending', 'reviewed', 'resolved', 'dismissed'
  createdAt    DateTime @default(now())
  reviewedAt   DateTime?
  reviewedBy   String?  // Admin who reviewed

  reporter     User     @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User?    @relation("ReportsAgainstUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reviewer     User?    @relation("ReportsReviewedBy", fields: [reviewedBy], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@map("reports")
}

model SavedGym {
  id        String   @id @default(uuid())
  userId    String
  gymId     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
  @@index([userId])
  @@index([gymId])
  @@map("saved_gyms")
}