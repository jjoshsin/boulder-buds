{
  "expo": {
    "name": "Boulder Buds",
    "slug": "boulder-buds",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.boulderbuds.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Boulder Buds needs access to your photo library to upload gym photos.",
        "NSCameraUsageDescription": "Boulder Buds needs access to your camera to take gym photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121419"
      },
      "package": "com.boulderbuds.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Boulder Buds to use your location to show nearby gyms."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Boulder Buds to access your photos to upload gym images."
        }
      ],
      "expo-video",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "10c8372a-bcff-4f00-827b-d75034133f8b"
      }
    }
  }
}
